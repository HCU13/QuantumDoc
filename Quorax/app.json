{
  "expo": {
    "name": "Quorax",
    "slug": "Quorax",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "quorax",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quorax.app",
      "buildNumber": "7",
      "associatedDomains": ["applinks:quorax.app"],
      "appleTeamId": "HBP69DD3KV",
      "infoPlist": {
        "GADApplicationIdentifier": "ca-app-pub-2610484857413432~2727020129",
        "NSCameraUsageDescription": "Quorax needs access to your camera to solve math problems and analyze images. For example, you can take a photo of a math problem to send to AI or perform visual content analysis.",
        "NSPhotoLibraryUsageDescription": "Quorax needs access to your photos to select images from your gallery for solving math problems and analyzing images. For example, you can select a previously taken photo of a math problem to send to AI or perform visual content analysis.",
        "NSUserNotificationsUsageDescription": "Quorax sends notifications to keep you updated on your study progress and important updates.",
        "CFBundleLocalizations": ["tr", "en"],
        "CFBundleDevelopmentRegion": "tr"
      }
    },
    "android": {
      "package": "com.quorax.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "quorax.app"
            },
            {
              "scheme": "quorax"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/logo.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-2610484857413432~2727020129",
          "androidAppId": "ca-app-pub-2610484857413432~6558089324"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "26b4db2d-44d2-47d2-8d68-f4f7b441cb55"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/26b4db2d-44d2-47d2-8d68-f4f7b441cb55"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
