{
  "expo": {
    "name": "Quorax",
    "slug": "Quorax",
    "version": "1.3.4",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "quorax",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quorax.app",
      "buildNumber": "10",
      "associatedDomains": [
        "applinks:quorax.app"
      ],
      "appleTeamId": "HBP69DD3KV",
      "infoPlist": {
        "GADApplicationIdentifier": "ca-app-pub-2610484857413432~2727020129",
        "NSCameraUsageDescription": "Quorax uses your camera so you can take a photo of a math problem, your own handwritten solution, or a worksheet for the AI to solve, verify, or turn into practice questions.",
        "NSPhotoLibraryUsageDescription": "Quorax accesses your photos so you can pick an existing image of a math problem, your solution, or a worksheet for the AI to solve, verify, or turn into practice questions.",
        "NSPhotoLibraryAddUsageDescription": "Quorax saves your exam results as images to your photo library so you can share them.",
        "NSUserNotificationsUsageDescription": "Quorax sends notifications to keep you updated on your study progress and important updates.",
        "CFBundleLocalizations": [
          "en"
        ],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "package": "com.quorax.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "quorax.app"
            },
            {
              "scheme": "quorax"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/logo.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-2610484857413432~2727020129",
          "androidAppId": "ca-app-pub-2610484857413432~6558089324"
        }
      ],
      "expo-font",
      [
        "@sentry/react-native",
        {
          "organization": "quorax",
          "project": "react-native",
          "url": "https://sentry.io"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "26b4db2d-44d2-47d2-8d68-f4f7b441cb55"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/26b4db2d-44d2-47d2-8d68-f4f7b441cb55"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "trooper13"
  }
}
