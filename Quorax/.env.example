# 🔐 QUORAX ENVIRONMENT VARIABLES
EXPO_PUBLIC_APP_NAME=Quorax
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_SCHEME=quorax

# 🔑 SUPABASE
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 📧 CONTACT
EXPO_PUBLIC_SUPPORT_EMAIL=support@quorax.app
EXPO_PUBLIC_PRIVACY_EMAIL=privacy@quorax.app

# 🔗 DEEP LINKS
EXPO_PUBLIC_DEEP_LINK_SCHEME=quorax
EXPO_PUBLIC_DEEP_LINK_HOST=quorax.app

# 📺 ADMOB REKLAMLAR
# Production reklam birimleri (store'da kullanılır)
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# Test reklamları kullan (development/TestFlight için)
# true = Google test reklamları, false = production reklamları
# EXPO_PUBLIC_USE_TEST_ADS=true

# 💳 REVENUECAT
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_ios_key
