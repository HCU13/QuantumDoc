{
  "expo": {
    "name": "Quorax",
    "slug": "Quorax",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "quorax",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1120"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quorax.app",
      "associatedDomains": ["applinks:quorax.app"],
      "appleTeamId": "HBP69DD3KV"
    },
    "android": {
      "package": "com.quorax.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "CAMERA",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "quorax.app"
            },
            {
              "scheme": "quorax"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "26b4db2d-44d2-47d2-8d68-f4f7b441cb55"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-localization",
      "expo-font"
    ],
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/26b4db2d-44d2-47d2-8d68-f4f7b441cb55"
    }
  }
}
