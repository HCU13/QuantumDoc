      "faqList": [
        {
          "id": "1",
          "question": "What is Quorax?",
          "answer": "Quorax is an AI-powered education platform. It offers AI chat, problem solver, and many more features."
        },
        {
          "id": "2",
          "question": "How can I earn tokens?",
          "answer": "You can earn tokens by completing daily missions, watching videos, or purchasing token packages."
        },
        {
          "id": "3",
          "question": "How do I change my password?",
          "answer": "You can update your password from Profile > Account Info > Change Password section."
        },
        {
          "id": "4",
          "question": "How can I cancel my subscription?",
          "answer": "You can cancel your subscription from Profile > Subscription page at any time. After cancellation, your subscription remains active until the end of the current period."
        },
        {
          "id": "5",
          "question": "How does the problem solver work?",
          "answer": "You can send your question to AI by typing or taking a photo. AI analyzes your problem and provides step-by-step solutions."
        },
        {
          "id": "6",
          "question": "Which languages are supported?",
          "answer": "Currently Turkish, English, German, French, and Spanish are supported. Our AI assistant responds in your selected language."
        },
        {
          "id": "7",
          "question": "Is my data safe?",
          "answer": "Yes! All your data is encrypted and processed in GDPR compliance. You can manage your privacy settings at any time."
        },
        {
          "id": "8",
          "question": "How do I delete my account?",
          "answer": "You can permanently delete your account from Profile > Account Info > Delete Account option. This action cannot be undone."
        }
      ]
    }
